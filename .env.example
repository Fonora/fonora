# Fonoran Google OAuth (loaded automatically from .env on npm start: local dev only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=

# Only @fonora.org accounts may sign in (default: fonora.org)
ALLOWED_DOMAIN=fonora.org

# Optional: restrict to specific emails instead of whole domain
# ADMIN_EMAILS=info@fonora.org

# Optional: force callback URL (default: derived from request host)
# AUTH_CALLBACK_URL=http://localhost:8000/auth/callback

# Local dev: skip auth even when OAuth vars are set
# FONORAN_AUTH=off   # local opt-out only — omit in production (Heroku)

# Optional: warn when preferred compounds flatten to more than N atomic roots (default 4)
# FONORAN_MAX_FLATTENED=4

# Optional: LLM-assisted compound candidate proposals (advisory only; playtests decide)
# LLM_API_KEY=
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini

# Anthropic — synthetic LLM playtests + optional proposer
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=512
# LLM_REQUEST_DELAY_MS=200
# LLM_MIN_RECOVERY=0.75
# LLM_MIN_COLD_RECOVERY=0.25
# LLM_MIN_MARGIN=0.15
# LLM_MIN_ROUNDS=4

# Fonoran storage (optional)
# DATABASE_URL=
# FONORAN_STORAGE=postgres
# FONORAN_SKIP_JSON_MIRROR=1

# External research data (Fonora/fonora-data submodule)
# FONORAN_DATA_DIR=external/fonora-data
# RESEARCH_NOTES_STORE_PATH=external/fonora-data/data/research-notes-store.json
# FONORAN_SKIP_DATA_FETCH=1   # skip GitHub tarball fetch (local submodule already present)
